  "repository": {
    "type": "git",
    "url": "https://github.com/HeJian1982/solar-system-explorer.git"
  },
  "keywords": [
    "solar-system",
    "astronomy",
    "three.js",
    "react-three-fiber",
    "nextjs",
    "3d-visualization",
    "education",
    "nasa-data"
  ],
  "private": false,
  "engines": {
